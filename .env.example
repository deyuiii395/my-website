# MongoDB 连接字符串示例
# 本地开发 (需要启动本地 MongoDB):
MONGODB_URI=mongodb://localhost:27017/gao33_score_system

# Render 部署 (使用 Render 提供的 MongoDB):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gao33_score_system?retryWrites=true&w=majority

# MongoDB Atlas (免费云服务):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gao33_score_system

# 服务端口 (本地默认 3000, Render 使用 10000)
PORT=3000
